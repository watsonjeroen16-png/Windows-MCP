# Kaizi server — example environment. Copy to .env and fill in.
# All values below are placeholders; NEVER commit real credentials.

PORT=4000

# PostgreSQL connection string (used by `npm run migrate` and the real db layer)
DATABASE_URL=postgres://postgres:kaizi@localhost:5432/kaizi

# Twilio — leave any of these unset to run in MOCK mode (no network calls;
# verification code "000000" approves, welcome SMS is logged instead of sent).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_MESSAGING_FROM=+15005550006

# Optional: enforce the 21:30-07:30 quiet-hours window on /api/sms/welcome
# (server-local time). Off by default so dev/CI can send any time.
KAIZI_ENFORCE_QUIET_HOURS=false
